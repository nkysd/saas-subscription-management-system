@model IEnumerable<SaasSubscriptionManagementSystem.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<h2>Audit Logs</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Audit Log ID</th>
            <th>Action</th>
            <th>Entity</th>
            <th>Performed By</th>
            <th>Timestamp</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.AuditLogId</td>
                <td>@log.Action</td>
                <td>@log.EntityName</td>
                <td>@log.PerformedBy</td>
                <td>@log.Timestamp</td>
                <td>@log.Details</td>
            </tr>
        }
    </tbody>
</table>